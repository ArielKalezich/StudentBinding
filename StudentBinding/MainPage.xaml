<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StudentBinding.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:StudentBinding"
    xmlns:models="clr-namespace:StudentBinding.Models"
    x:DataType="local:MainPage"
    >

    <ScrollView>
        <VerticalStackLayout Padding="30,0" Spacing="25">
            <!--  תמונת פרופיל  -->
            <Image
                Aspect="AspectFit"
                HeightRequest="185"
                SemanticProperties.Description="Student profile image"
                Source="{Binding CurrentStudent.Image}" />

            <!--  שם התלמיד  -->
            <Label
                FontAttributes="Bold"
                FontSize="32"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                SemanticProperties.HeadingLevel="Level1"
                Text="{Binding CurrentStudent.Name}"
                TextColor="MidnightBlue" />

            <!--  גיל  -->
            <Label
                FontSize="24"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                SemanticProperties.Description="Student age"
                SemanticProperties.HeadingLevel="Level2"
                Text="{Binding CurrentStudent.Age}"
                TextColor="MidnightBlue" />

            <!--  תאריך לידה  -->
            <DatePicker
                x:Name="BirthDatePicker"
                Date="{Binding CurrentStudent.BirthDate}"
                FontSize="24"
                HorizontalOptions="Center"
                SemanticProperties.Description="Student birth date"
                TextColor="MidnightBlue" />

            <!--  כתובת מייל  -->
            <Label
                FontSize="24"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                SemanticProperties.Description="Student email address"
                Text="{Binding CurrentStudent.Email}"
                TextColor="MidnightBlue" />

            <!--  טלפון  -->
            <Label
                FontSize="24"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                SemanticProperties.Description="Student phone number"
                Text="{Binding  CurrentStudent.PhoneNum}"
                TextColor="MidnightBlue" />
            <Button
     Clicked="StudentChangeOnClick"
     Text="שנה נתוני סטודנט"
     />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>